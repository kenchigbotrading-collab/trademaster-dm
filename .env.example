# ============================================================
# .env.example — TradeMaster DM Automation System
# Copy to .env and fill in your real values.
# NEVER commit .env to git.
# ============================================================

# ── Server ────────────────────────────────────────────────────
PORT=3000
NODE_ENV=production

# ── Anthropic Claude ──────────────────────────────────────────
ANTHROPIC_API_KEY=sk-ant-...

# ── Supabase ──────────────────────────────────────────────────
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_KEY=eyJ...   # Service role key — keep SECRET

# ── ManyChat ──────────────────────────────────────────────────
MANYCHAT_API_KEY=...           # From ManyChat Settings > API

# ── Webhook Security ──────────────────────────────────────────
WEBHOOK_SECRET=your_random_secret_here   # Verify ManyChat requests

# ── Optional: Sentry error monitoring ────────────────────────
SENTRY_DSN=https://...

# ── Optional: Upstash Redis (for rate limiting) ───────────────
UPSTASH_REDIS_URL=https://...
UPSTASH_REDIS_TOKEN=...
